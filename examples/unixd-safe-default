# Netidm Unixd minimal Service Configuration - /etc/netidm/unixd
# For a full example and documentation, see /usr/share/netidm-unixd/unixd
# or `example/unixd` in the source repository

version = '2'

# Steps to enable the Netidm auth provider:
# 1. Uncomment the `[netidm]` line below to enable the provider.
# 2. Set the `pam_allowed_login_groups` option to one or more valid posix groups.
# 3. Also update /etc/netidm/config and set the `idm_uri` option.

# [netidm]
# WITHOUT THIS SET, NOBODY WILL BE ABLE TO LOG IN VIA PAM
#
# pam_allowed_login_groups = ["your_posix_login_group"]
# default_shell = "/bin/sh"
# home_attr = "uuid"
# home_alias = "spn"
# use_etc_skel = false
