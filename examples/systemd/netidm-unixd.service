# You should not need to edit this file. Instead, use a drop-in file by running:
#   systemctl edit netidm-unixd.service

[Unit]
Description=Netidm Local Client Resolver
After=chronyd.service ntpd.service network-online.target

[Service]
DynamicUser=yes
Type=notify-reload
ExecStart=/usr/local/sbin/netidm_unixd

CacheDirectory=netidm-unixd
RuntimeDirectory=netidm-unixd
UMask=0027

[Install]
WantedBy=multi-user.target
