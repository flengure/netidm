# this  example configures netidm-unixd for testing on macos
db_path = "/tmp/netidm-unixd"
sock_path = "/tmp/netidm_unixd.sock"
task_sock_path = "/tmp/netidm_unixd_task.sock"
# some documentation is here: https://github.com/netidm/netidm/blob/master/book/src/pam_and_nsswitch.md
pam_allowed_login_groups = ["posix_group"]
